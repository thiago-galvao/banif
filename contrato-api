<Página de LOGIN>

POST '/api/v1/login'
{
	"data" {
		"email": "thiago@hotmail.com",
		"senha": "123456"
	}
}

*Se ok*
{
	status: 'success',
	message: 'Acesso liberado!',
	data: {
		token: 'abc_123_token',
		user: { 
			id: 1, 
			nome: 'Thiago' 
		}
	}
}

*Se não ok*
{
	status: 'error',
	message: 'Credenciais inválidas',
	data: null
}

