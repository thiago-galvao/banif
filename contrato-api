<Página APLICAR POUPANÇA>

GET 'api/v1/cliente/aplicar-poupanca'

*Se ok*
{
	"status":"success",
	"data": {
		"conta": {
			"saldo": 324.51,
			"tipo": "poupanca", // tipo de conta deve ser fixo em "poupanca", é uma tela de exibição de saldo da conta poupança.
			"agencia": "21342-09", // agencia da conta poupança
			"numero": "123948", // numero da conta poupanca
		}
	}
}

*Se não ok*
{
	"status": "error",
	"message": "Ocorreu um erro inesperado.",
	"data": null
}


