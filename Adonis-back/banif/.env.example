# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database (MySQL)
# Em dev local com docker-compose: DB_HOST=127.0.0.1
# Em VM: DB_HOST=<ip_da_vm>
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=banif_user
DB_PASSWORD=banif123
DB_DATABASE=banif

# Mail (vazio ou log = log no console; smtp = SMTP real)
MAIL_DRIVER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@banif.com

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
